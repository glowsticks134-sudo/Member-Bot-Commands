# ─── Discord Bot Credentials ─────────────────────────────────────────────────
# Found in the Discord Developer Portal (https://discord.com/developers/applications)

# Bot Token — Bot tab → Token
DISCORD_BOT_TOKEN=your_bot_token_here

# Application (Client) ID — General Information → Application ID
DISCORD_CLIENT_ID=your_client_id_here

# Client Secret — General Information → Client Secret
DISCORD_CLIENT_SECRET=your_client_secret_here

# ─── OAuth2 Redirect URI ──────────────────────────────────────────────────────
# The full public URL where Discord sends users after they authorize.
# Must exactly match a Redirect URI you set in the Discord Developer Portal
# under OAuth2 → Redirects.
#
# Example for a VPS:  https://yourdomain.com/redirect
# Example for local:  http://localhost:8080/redirect
REDIRECT_URI=https://yourdomain.com/redirect

# ─── Server Port ─────────────────────────────────────────────────────────────
# The port the API server listens on.
PORT=8080
